---
import Base from '../layouts/Base.astro';
const jsonld = [{
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'HubESOL',
  url: 'https://hubesol.com/',
  description: 'Free English grammar lessons, interactive exercises and printable resources for ESOL students and teachers.',
}];
---
<Base
  title="HubESOL — English grammar lessons, exercises and teacher resources"
  description="Clear English grammar explanations with interactive quizzes and printable lesson packs. Free, organised by topic and CEFR level."
  jsonld={jsonld}
>
  <h1>Master English grammar, one clear answer at a time.</h1>
  <p>
    Short explanations, instant-feedback quizzes and printable resources —
    organised by <a href="/grammar/">topic</a> and CEFR level. Free, no sign-up needed.
  </p>

  <h2>Grammar hubs</h2>
  <div class="cards">
    <a class="card" href="/grammar/verb-tenses/">
      <h3>Verb Tenses</h3>
      <p>All 12 English tenses, with contrasts like present perfect vs past simple.</p>
    </a>
    <a class="card soon" href="/grammar/">
      <h3>Conditionals <span class="badge">soon</span></h3>
      <p>Zero to mixed conditionals, wishes and transformations.</p>
    </a>
    <a class="card soon" href="/grammar/">
      <h3>Modal Verbs <span class="badge">soon</span></h3>
      <p>Ability, obligation, probability and modal perfects.</p>
    </a>
    <a class="card soon" href="/grammar/">
      <h3>Reported Speech <span class="badge">soon</span></h3>
      <p>Backshift, reporting verbs, say vs tell.</p>
    </a>
  </div>

  <section class="newsletter" id="newsletter">
    <h2 style="margin-top:0">📬 Get the free cheat sheets</h2>
    <p>One short email every two weeks: a grammar tip, a common mistake, and a printable PDF. No spam.</p>
    <!-- TODO: replace action with your MailerLite/Brevo form endpoint -->
    <form action="#" method="post">
      <input type="email" name="email" placeholder="your@email.com" required />
      <button class="btn" type="submit">Subscribe free</button>
    </form>
  </section>
</Base>
