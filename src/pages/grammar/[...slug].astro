---
import { getCollection } from 'astro:content';
import Lesson from '../../layouts/Lesson.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);
  return lessons.map((l) => ({ params: { slug: l.slug }, props: { lesson: l } }));
}

const { lesson } = Astro.props;
const { Content } = await lesson.render();

const quizModules = import.meta.glob('../../data/quizzes/*.json', { eager: true });
const quizKey = `../../data/quizzes/${lesson.data.quiz}.json`;
const quiz = lesson.data.quiz ? (quizModules[quizKey]?.default ?? quizModules[quizKey] ?? null) : null;
---
<Lesson lesson={lesson} quiz={quiz}><Content /></Lesson>
