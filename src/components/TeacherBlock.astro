---
const { objectives, title, packHref } = Astro.props;
---
{objectives.length > 0 && (
  <section class="teacher">
    <h2>👩‍🏫 For teachers</h2>
    <p><strong>CEFR objectives for “{title}”:</strong></p>
    <ul>
      {objectives.map((o) => <li>{o}</li>)}
    </ul>
    <p class="pack-cta">
      <a class="btn" href={packHref} download>⬇︎ Download the Lesson Pack (PDF)</a>
    </p>
    <p class="pack-note">
      Printable worksheet + answer key + one-page summary. Free to use and print in class with
      attribution. <a href="/#newsletter">Join the newsletter</a> for new packs and cheat sheets.
    </p>
  </section>
)}
