{
  "id": "this-that-these-those-quiz-1",
  "title": "This, That, These & Those",
  "level": "A1",
  "items": [
    {
      "question": "___ book in my hand is really good.",
      "options": ["This", "These", "That", "Those"],
      "answer": 0,
      "explanations": [
        "Correct! Near + singular = 'this book'.",
        "'These' is plural.",
        "'That' is for far things.",
        "'Those' is far and plural."
      ]
    },
    {
      "question": "Look at ___ birds in the sky over there.",
      "options": ["those", "these", "this", "that"],
      "answer": 0,
      "explanations": [
        "Correct! Far + plural = 'those birds'.",
        "'These' is for near things.",
        "'This' is singular.",
        "'That' is singular."
      ]
    },
    {
      "question": "___ shoes I'm wearing are new.",
      "options": ["These", "This", "That", "Those"],
      "answer": 0,
      "explanations": [
        "Correct! Near + plural = 'these shoes'.",
        "'This' is singular.",
        "'That' is singular and far.",
        "'Those' is far."
      ]
    },
    {
      "question": "Can you see ___ house on the hill?",
      "options": ["that", "this", "these", "those"],
      "answer": 0,
      "explanations": [
        "Correct! Far + singular = 'that house'.",
        "'This' is for near things.",
        "'These' is plural.",
        "'Those' is plural."
      ]
    },
    {
      "question": "___ is my sister, Anna. (introducing someone next to you)",
      "options": ["This", "That", "These", "Those"],
      "answer": 0,
      "explanations": [
        "Correct! We introduce a near person with 'This is…'.",
        "'That is' points to someone further away.",
        "'These' is plural.",
        "'Those' is plural."
      ]
    },
    {
      "question": "Whose keys are ___ on the far table?",
      "options": ["those", "these", "this", "that"],
      "answer": 0,
      "explanations": [
        "Correct! Far + plural (as a pronoun) = 'those'.",
        "'These' is for near things.",
        "'This' is singular.",
        "'That' is singular."
      ]
    },
    {
      "question": "I love ___ song that's playing right now.",
      "options": ["this", "these", "those", "that one's"],
      "answer": 0,
      "explanations": [
        "Correct! Something happening now/near = 'this song'.",
        "'These' is plural.",
        "'Those' is far and plural.",
        "'That one's' doesn't fit before 'song'."
      ]
    },
    {
      "question": "___ days, everyone used a paper map. (distant past)",
      "options": ["In those", "In these", "In this", "In that"],
      "answer": 0,
      "explanations": [
        "Correct! A distant time takes 'those': 'In those days'.",
        "'These days' means now.",
        "'This' is singular.",
        "'That' is singular."
      ]
    },
    {
      "question": "Correct this: 'This apples are sweet.'",
      "options": [
        "These apples are sweet.",
        "This apples are sweet.",
        "That apples are sweet.",
        "The sentence is already correct."
      ],
      "answer": 0,
      "explanations": [
        "Correct! Plural noun needs a plural demonstrative: 'These apples'.",
        "'This' can't go with the plural 'apples'.",
        "'That' is also singular.",
        "'This apples' mismatches number."
      ]
    },
    {
      "question": "Which pair is NEAR + PLURAL?",
      "options": ["these", "this", "that", "those"],
      "answer": 0,
      "explanations": [
        "Correct! 'These' = near and plural.",
        "'This' is near but singular.",
        "'That' is far and singular.",
        "'Those' is far and plural."
      ]
    }
  ]
}
