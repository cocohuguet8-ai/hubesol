  "id": "the-with-names-and-places-quiz-1",
  "title": "The with Names & Places",
  "level": "B1",
  "items": [
    {
      "question": "My cousin lives in ___ Netherlands.",
      "options": ["the", "a", "—", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Plural country names take 'the': 'the Netherlands'.",
        "Countries don't take 'a'.",
        "This plural name needs 'the', unlike France.",
        "Countries don't take 'an'."
      ]
    },
    {
      "question": "We took a boat down ___ Amazon.",
      "options": ["the", "a", "—", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Rivers take 'the': 'the Amazon'.",
        "Rivers don't take 'a'.",
        "Rivers take 'the', not zero article.",
        "Rivers don't take 'an'."
      ]
    },
    {
      "question": "She's studying in ___ Japan this year.",
      "options": ["—", "the", "a", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Most countries take no article: 'Japan'.",
        "Ordinary country names don't take 'the'.",
        "Countries don't take 'a'.",
        "Countries don't take 'an'."
      ]
    },
    {
      "question": "They climbed ___ Mount Everest.",
      "options": ["—", "the", "a", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Single mountains take no article: 'Mount Everest'.",
        "Single mountains don't take 'the' (but ranges do).",
        "Mountains don't take 'a'.",
        "Mountains don't take 'an'."
      ]
    },
    {
      "question": "We hiked in ___ Alps last summer.",
      "options": ["the", "—", "a", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Mountain ranges take 'the': 'the Alps'.",
        "Ranges take 'the', unlike single mountains.",
        "Ranges don't take 'a'.",
        "Ranges don't take 'an'."
      ]
    },
    {
      "question": "The tour includes ___ British Museum.",
      "options": ["the", "a", "—", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Institutions with a common noun take 'the': 'the British Museum'.",
        "It doesn't take 'a'.",
        "This name needs 'the'.",
        "It doesn't take 'an'."
      ]
    },
    {
      "question": "He flew into ___ Heathrow Airport.",
      "options": ["—", "the", "a", "an"],
      "answer": 0,
      "explanations": [
        "Correct! Airports named after a place take no article: 'Heathrow Airport'.",
        "This name doesn't take 'the'.",
        "Airports don't take 'a'.",
        "Airports don't take 'an'."
      ]
    },
    {
      "question": "She graduated from ___ University of Cambridge.",
      "options": ["the", "a", "—", "an"],
      "answer": 0,
      "explanations": [
        "Correct! 'the University of X' takes 'the'.",
        "It doesn't take 'a'.",
        "The 'of' pattern needs 'the'.",
        "It doesn't take 'an'."
      ]
    },
    {
      "question": "Correct this: 'We sailed across Pacific.'",
