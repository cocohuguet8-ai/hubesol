    {
      "question": "Which type of name takes 'the'?",
      "options": [
        "Rivers, seas and mountain ranges.",
        "Single cities.",
        "Single lakes.",
        "Most countries."
      ],
      "answer": 0,
      "explanations": [
        "Correct! Rivers, seas and ranges take 'the' (the Nile, the Alps).",
