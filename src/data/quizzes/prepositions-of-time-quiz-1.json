{
  "id": "prepositions-of-time-quiz-1",
  "title": "Prepositions of Time: at/on/in",
  "level": "A2",
  "items": [
    {
      "question": "The film starts ___ 8 o'clock.",
      "options": ["at", "on", "in", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Clock times take 'at': 'at 8 o'clock'.",
        "'On' is for days and dates.",
        "'In' is for longer periods.",
        "A clock time needs 'at'."
      ]
    },
    {
      "question": "We have a meeting ___ Monday.",
      "options": ["on", "at", "in", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Days take 'on': 'on Monday'.",
        "'At' is for clock times and points.",
        "'In' is for longer periods.",
        "A day needs 'on'."
      ]
    },
    {
      "question": "It often snows ___ January.",
      "options": ["in", "on", "at", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Months take 'in': 'in January'.",
        "'On' is for days and dates.",
        "'At' is for clock times.",
        "A month needs 'in'."
      ]
    },
    {
      "question": "I'll see you ___ tomorrow.",
      "options": ["—", "on", "at", "in"],
      "answer": 0,
      "explanations": [
        "Correct! 'Tomorrow' takes no preposition: 'See you tomorrow'.",
        "Don't use 'on' before 'tomorrow'.",
        "Don't use 'at' before 'tomorrow'.",
        "Don't use 'in' before 'tomorrow'."
      ]
    },
    {
      "question": "She was born ___ 2001.",
      "options": ["in", "on", "at", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Years take 'in': 'in 2001'.",
        "'On' is for days and dates.",
        "'At' is for clock times.",
        "A year needs 'in'."
      ]
    },
    {
      "question": "I don't like driving ___ night.",
      "options": ["at", "in", "on", "—"],
      "answer": 0,
      "explanations": [
        "Correct! 'At night' is a fixed expression.",
        "'In night' is wrong (but 'in the morning' is correct).",
        "'On night' is not correct.",
        "'Night' needs 'at' here."
      ]
    },
    {
      "question": "We usually go out ___ the evening.",
      "options": ["in", "at", "on", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Parts of the day take 'in': 'in the evening'.",
        "'At' is used only in 'at night'.",
        "'On' is for days and dates.",
        "'The evening' needs 'in'."
      ]
    },
    {
      "question": "Her birthday is ___ 14 February.",
      "options": ["on", "in", "at", "—"],
      "answer": 0,
      "explanations": [
        "Correct! Dates take 'on': 'on 14 February'.",
        "'In' is for months alone (in February).",
        "'At' is for clock times.",
        "A full date needs 'on'."
      ]
    },
    {
      "question": "Correct this: 'I'll call you in Monday morning.'",
      "options": [
        "I'll call you on Monday morning.",
        "I'll call you at Monday morning.",
        "I'll call you in Monday morning.",
        "I'll call you Monday in morning."
      ],
      "answer": 0,
      "explanations": [
        "Correct! With a specific day, use 'on': 'on Monday morning'.",
        "'At Monday' is wrong for a day.",
        "'In Monday' is wrong for a day.",
        "This word order is incorrect."
      ]
    },
    {
      "question": "Which preposition goes with a clock time?",
      "options": ["at", "on", "in", "no preposition"],
      "answer": 0,
      "explanations": [
        "Correct! Clock times take 'at': at 6, at 9:30.",
        "'On' is for days and dates.",
        "'In' is for longer periods.",
        "Clock times do take a preposition — 'at'."
      ]
    }
  ]
}
