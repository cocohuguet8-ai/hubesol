---
import Base from './Base.astro';
import Quiz from '../components/Quiz.astro';
import Faq from '../components/Faq.astro';
import TeacherBlock from '../components/TeacherBlock.astro';

const { lesson, quiz } = Astro.props;
const d = lesson.data;
const url = new URL(Astro.url.pathname, Astro.site).href;

const jsonld = [
  {
    '@context': 'https://schema.org',
    '@type': 'LearningResource',
    name: d.title,
    description: d.description,
    educationalLevel: d.level,
    learningResourceType: 'Lesson',
    inLanguage: 'en',
    url,
    isPartOf: { '@type': 'WebSite', name: 'HubESOL', url: 'https://hubesol.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Grammar', item: 'https://hubesol.com/grammar/' },
      { '@type': 'ListItem', position: 2, name: d.hub, item: `https://hubesol.com/grammar/${d.hubSlug}/` },
      { '@type': 'ListItem', position: 3, name: d.title, item: url },
    ],
  },
];

if (d.faq.length > 0) {
  jsonld.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: d.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

if (quiz) {
  jsonld.push({
    '@context': 'https://schema.org',
    '@type': 'Quiz',
    name: quiz.title,
    educationalLevel: quiz.level,
    hasPart: quiz.items.map((item) => ({
      '@type': 'Question',
      eduQuestionType: 'Multiple choice',
      text: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.options[item.answer] },
      suggestedAnswer: item.options
        .filter((_, j) => j !== item.answer)
        .map((o) => ({ '@type': 'Answer', text: o })),
    })),
  });
}
---
<Base title={`${d.title} — HubESOL`} description={d.description} jsonld={jsonld}>
  <p class="crumbs">
    <a href="/grammar/">Grammar</a> › <a href={`/grammar/${d.hubSlug}/`}>{d.hub}</a> › {d.title}
  </p>
  <h1>{d.title}</h1>
  <p class="meta"><span class="badge">{d.level}</span>{d.description}</p>

  <div class="answer-box">
    <span class="label">Quick answer</span>
    {d.answerPoints && d.answerPoints.length > 0 ? (
      <>
        {d.answerLead && <p class="answer-lead">{d.answerLead}</p>}
        <ol class="answer-points">
          {d.answerPoints.map((p) => <li>{p}</li>)}
        </ol>
        {d.answerNote && <p class="answer-note">{d.answerNote}</p>}
      </>
    ) : (
      <p>{d.answerBox}</p>
    )}
  </div>

  <div class="prose"><slot /></div>

  <Quiz quiz={quiz} />
  <Faq faq={d.faq} />
  <TeacherBlock objectives={d.teacherObjectives} title={d.title} />

  {d.related.length > 0 && (
    <section>
      <h2>Keep learning</h2>
      <ul>
        {d.related.map((r) => <li><a href={r.href}>{r.title}</a></li>)}
      </ul>
    </section>
  )}
</Base>
