---
import '../styles/global.css';
const { title, description, jsonld = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <script is:inline>
      try { if (localStorage.getItem('hubesol-teacher') === 'off') document.documentElement.classList.add('no-teacher'); } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    {jsonld.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
  </head>
  <body>
    <header class="site">
      <div class="inner">
        <a class="logo" href="/" aria-label="HubESOL home">
          <svg class="logo-mark" width="28" height="28" viewBox="0 0 32 32" aria-hidden="true"><rect width="32" height="32" rx="9" fill="#4f46e5"/><path d="M9 8.5h14a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8l-4 3.2V20.5H9a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2Z" fill="#fff"/><path d="M11.5 14.3l2.6 2.6 5-5.2" fill="none" stroke="#4f46e5" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span class="logo-text">Hub<span>ESOL</span></span>
        </a>
        <nav class="main">
          <a href="/grammar/">Grammar</a>
          <a href="/teachers/lesson-packs/">Teachers</a>
          <a href="/#newsletter">Newsletter</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site">
      <div class="inner">
        © {new Date().getFullYear()} HubESOL — Free English grammar lessons and exercises.
        <span style="margin-left:1rem">·</span>
        <label class="tmode" style="margin-left:1rem"><input type="checkbox" id="tmode-toggle" /> Teacher mode</label>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var el = document.getElementById('tmode-toggle');
        if (!el) return;
        var off = false;
        try { off = localStorage.getItem('hubesol-teacher') === 'off'; } catch (e) {}
        el.checked = !off;
        el.addEventListener('change', function () {
          try { localStorage.setItem('hubesol-teacher', el.checked ? 'on' : 'off'); } catch (e) {}
          document.documentElement.classList.toggle('no-teacher', !el.checked);
        });
      })();
    </script>
  </body>
</html>
